{
  "name": "@tertium/js",
  "version": "1.4.7",
  "description": "Shared JS configs and types.",
  "type": "module",
  "exports": {
    "./core/*": "./core/*",
    "./entities/*": "./entities/*",
    "./scripts/*": "./scripts/*"
  },
  "files": [
    "scripts/",
    "core/",
    "entities/"
  ],
  "scripts": {
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "test": "echo \"no test specified\" && exit 0",
    "lint": "biome check scripts core entities",
    "format": "biome format scripts core entities",
    "biome-check": "biome check scripts core entities",
    "lint:fix": "biome check --write scripts core entities"
  },
  "author": "Vitalii Balabanov",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.0.9",
    "typescript": "^5.8.3"
  }
}
